# NL2Firewall environment configuration
# Copy this file to .env and fill in your values

# ─── Required ────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_google_api_key_here

# ─── Optional — defaults shown ───────────────────────────────────────────────

BATFISH_HOST=localhost
BATFISH_PORT=9996
BATFISH_NETWORK=nl2firewall

LOG_LEVEL=INFO
DEBUG=false

SNMT_PATH=data/snmt/ccna_lab.yaml
